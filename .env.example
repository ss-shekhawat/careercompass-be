# Database — Neon Postgres connection string
# Get from: https://console.neon.tech → Project → Connection Details
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=postgresql://user:pass@localhost:5432/careercompass

# JWT — generate a real one with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-to-a-long-random-string-min-64-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS — comma-separated list of allowed origins
# Local dev + your Vercel deployment URL
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Environment marker (local | dev | prod)
ENV=local
